{
  "schema": "gee.gear.v1",
  "id": "media.library",
  "name": "Media Library",
  "description": "Eagle-compatible local media manager with folders, previews, stars, filters, Quick Look, and agent-ready controls.",
  "developer": "Gee",
  "version": "0.1.0",
  "category": "Media",
  "kind": "atmosphere",
  "display_mode": "full_canvas",
  "cover": "assets/cover.png",
  "icon": "assets/icon.png",
  "entry": {
    "type": "native",
    "native_id": "media.library"
  },
  "agent": {
    "enabled": true,
    "capabilities": [
      {
        "id": "media.filter",
        "title": "Filter media",
        "description": "Change the visible media set by folder, media kind, star state, duration, or search text.",
        "examples": [
          "Show videos only",
          "Show starred images only",
          "Show only mp4 files longer than 3 minutes"
        ],
        "input_schema": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "kind": {
              "type": "string",
              "enum": ["all", "image", "video"]
            },
            "extensions": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "starred_only": {
              "type": "boolean"
            },
            "minimum_duration_seconds": {
              "type": "number"
            },
            "search_text": {
              "type": "string"
            },
            "folder_name": {
              "type": "string"
            }
          }
        },
        "side_effect": "native_view_state",
        "permissions": ["gear.surface.view_state"],
        "exports": {
          "codex": {
            "enabled": true,
            "risk": "low",
            "requires_approval": false,
            "skill_hint": "Use when Codex needs GeeAgent Media Library to focus its visible set without reading or writing user files."
          }
        }
      },
      {
        "id": "media.focus_folder",
        "title": "Focus folder",
        "description": "Switch the media browser to a named folder or uncategorized view.",
        "examples": [
          "Switch to the Assets folder",
          "Show uncategorized files only"
        ],
        "input_schema": {
          "type": "object",
          "required": ["folder_name"],
          "additionalProperties": false,
          "properties": {
            "folder_name": {
              "type": "string"
            }
          }
        },
        "side_effect": "native_view_state",
        "permissions": ["gear.surface.view_state"],
        "exports": {
          "codex": {
            "enabled": true,
            "risk": "low",
            "requires_approval": false,
            "skill_hint": "Use when Codex needs GeeAgent Media Library to switch to a known folder or uncategorized view."
          }
        }
      },
      {
        "id": "media.import_files",
        "title": "Import local media files",
        "description": "Import local image or video file paths into the authorized Eagle-compatible media library, restoring saved access when possible and returning imported item paths.",
        "examples": [
          "Import these downloaded videos into the media library",
          "Add these local media files to Media Library"
        ],
        "input_schema": {
          "type": "object",
          "required": ["paths"],
          "additionalProperties": false,
          "properties": {
            "paths": {
              "type": "array",
              "minItems": 1,
              "maxItems": 200,
              "items": {
                "type": "string"
              },
              "description": "Local image or video file paths to import into the authorized Media Library."
            }
          }
        },
        "output_schema": {
          "type": "object",
          "properties": {
            "status": {
              "type": "string",
              "enum": ["succeeded", "failed"]
            },
            "action": {
              "type": "string",
              "enum": ["imported_files", "import_noop", "import_skipped", "authorization_required"]
            },
            "requested_paths": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "pending_paths": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "missing_paths": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "unsupported_paths": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "duplicate_paths": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "imported_count": {
              "type": "integer"
            },
            "existing_count": {
              "type": "integer"
            },
            "available_count": {
              "type": "integer"
            },
            "library_path": {
              "type": "string"
            },
            "imported_items": {
              "type": "array",
              "items": {
                "type": "object"
              }
            },
            "existing_items": {
              "type": "array",
              "items": {
                "type": "object"
              }
            },
            "available_items": {
              "type": "array",
              "items": {
                "type": "object"
              }
            },
            "code": {
              "type": "string"
            },
            "error": {
              "type": "string"
            },
            "recovery": {
              "type": "string"
            }
          }
        },
        "side_effect": "media_library.import_files",
        "permissions": [
          "filesystem.read.user_selected",
          "media.library.write",
          "gear_data.write",
          "gear.surface.view_state"
        ],
        "exports": {
          "codex": {
            "enabled": true,
            "risk": "high",
            "requires_approval": false,
            "skill_hint": "Use only when the current user message explicitly asks Codex to import local media files into GeeAgent Media Library. Pass only local paths supplied by the user or returned by Gee capabilities, and report structured imported_items/existing_items or authorization_required failures."
          }
        }
      }
    ]
  }
}
